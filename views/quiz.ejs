<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Therapy Type Quiz</title>
</head>
<body>
    <main>
        <h1>What's your therapy type?</h1>
        <div id="quiz-container">
            <% if (sessionData.currentStep !== "end") { %>
                <!-- Display the question for the current step -->
                <p><%= sessionData.question %></p>
                
                <!-- Display the answers for the current step -->
                <% if (sessionData.answers && sessionData.answers.length > 0) { %>
                    <% sessionData.answers.forEach(function(answer) { %>
                        <form action="/quiz/handleQuizStep" method="POST">
                            <button type="submit" name="userInput" value="<%= answer.text %>"><%= answer.text %></button>
                        </form>
                    <% }); %>
                <% } else { %>
                    <p>Click the button to start the quiz.</p>
                    <form action="/quiz/handleQuizStep" method="POST">
                        <button type="submit" name="userInput" value="Start Quiz">Start Quiz</button>
                    </form>
                <% } %>
            <% } else { %>
                <!-- Display the final message -->
                <p><%= sessionData.message %></p>
            <% } %>
        </div>
    </main>
</body>
</html>
